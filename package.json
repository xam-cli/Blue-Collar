{
  "name": "bluecollar",
  "version": "1.0.0",
  "description": "BlueCollar - Decentralised protocol built on Stellar that connects local skilled workers with users through community-curated listings",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter @bluecollar/api dev\" \"pnpm --filter @bluecollar/app dev\"",
    "build": "pnpm --filter @bluecollar/api build && pnpm --filter @bluecollar/app build",
    "test": "pnpm --filter @bluecollar/api test && pnpm --filter @bluecollar/app test",
    "lint": "pnpm --filter @bluecollar/api lint && pnpm --filter @bluecollar/app lint",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,json,md}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3"
  },
  "license": "MIT"
}
