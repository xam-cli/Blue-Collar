# ─── API ──────────────────────────────────────────────────────────────────────

# Base URL of the BlueCollar API (no trailing slash)
# Example: https://api.bluecollar.app
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# ─── Stellar ──────────────────────────────────────────────────────────────────

# Stellar network to connect to: TESTNET | MAINNET
NEXT_PUBLIC_STELLAR_NETWORK="TESTNET"

# Deployed Soroban Market contract ID
# Example: CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_MARKET_CONTRACT_ID=""

# Deployed Soroban Registry contract ID
# Example: CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_REGISTRY_CONTRACT_ID=""
