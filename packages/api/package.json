{
  "name": "@bluecollar/api",
  "version": "1.0.0",
  "description": "Backend API for BlueCollar - a decentralized protocol connecting local skilled workers with users",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest",
    "migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "seed": "tsx src/database/seed.ts",
    "seed:reset": "tsx src/database/seed.ts --reset",
    "admin:create": "tsx src/commands/create-admin.ts",
    "db:reset": "tsx src/commands/reset-db.ts"
  },
  "prisma": {
    "seed": "tsx src/database/seed.ts"
  },
  "keywords": [
    "skilled-workers",
    "stellar",
    "decentralized",
    "marketplace"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^7.2.0",
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.9",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.3.1",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "simple-body-validator": "^1.3.9",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "latest",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/method-override": "^3.0.0",
    "@types/multer": "^1",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6",
    "@types/passport": "^0",
    "@types/passport-google-oauth20": "^2",
    "prisma": "^7.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
