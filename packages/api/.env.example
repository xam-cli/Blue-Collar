# Database connection
# PostgreSQL database URL (e.g., postgresql://user:password@localhost:5432/bluecollar)
DATABASE_URL="postgresql://user:password@localhost:5432/bluecollar"

# JWT Authentication
# Secret key used for signing JSON Web Tokens
JWT_SECRET="change-me-in-production"

# Application
# Port number the API server will listen on
PORT=3000
# The base URL of the frontend application (used for OAuth redirects, CORS, emails, etc.)
APP_URL="http://localhost:3000"

# Google OAuth
# Client ID for Google OAuth 2.0 integration
GOOGLE_CLIENT_ID="google-client-id"
# Client Secret for Google OAuth 2.0 integration
GOOGLE_CLIENT_SECRET="google-client-secret"

# Email Service (SMTP)
# SMTP Host for sending emails (e.g., smtp.gmail.com)
MAIL_HOST=""
# SMTP Port for sending emails (typically 587 for TLS, or 465 for SSL)
MAIL_PORT=587
# SMTP Username (your email address)
MAIL_USER=""
# SMTP Password (your email password or app-specific password)
MAIL_PASS=""
