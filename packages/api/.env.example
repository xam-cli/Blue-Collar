# ─── Database ────────────────────────────────────────────────────────────────

# PostgreSQL connection string for the main database
# Example: postgresql://user:password@localhost:5432/bluecollar
DATABASE_URL="postgresql://user:password@localhost:5432/bluecollar"

# Separate database used only when running tests (never points at production data)
# Example: postgresql://user:password@localhost:5432/bluecollar_test
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/bluecollar_test"

# ─── Authentication ───────────────────────────────────────────────────────────

# Secret key used to sign JSON Web Tokens — use a long random string in production
# Example: openssl rand -hex 64
JWT_SECRET="change-me-in-production"

# ─── Application ─────────────────────────────────────────────────────────────

# Port the API server listens on
# Default: 3000
PORT=3000

# Runtime environment: development | test | production
NODE_ENV="development"

# Log verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL="info"

# Public URL of the frontend app — used in emails and OAuth redirects
# Example: https://bluecollar.app
APP_URL="http://localhost:3001"

# Comma-separated list of origins allowed by CORS
# Example: https://bluecollar.app,https://admin.bluecollar.app
ALLOWED_ORIGINS="http://localhost:3001"

# ─── Rate Limiting ────────────────────────────────────────────────────────────

# Time window for rate limiting in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per IP within the window
RATE_LIMIT_MAX=100

# ─── File Uploads ─────────────────────────────────────────────────────────────

# Directory where uploaded files are stored (relative to project root)
UPLOAD_DIR="storage/uploads"

# Maximum allowed upload size in bytes (default: 5 MB)
MAX_FILE_SIZE=5242880

# ─── Google OAuth ─────────────────────────────────────────────────────────────

# OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# OAuth 2.0 Client Secret from Google Cloud Console
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email / SMTP ─────────────────────────────────────────────────────────────

# SMTP server hostname (e.g., smtp.gmail.com, smtp.sendgrid.net)
MAIL_HOST="smtp.example.com"

# SMTP port — 587 for STARTTLS, 465 for SSL
MAIL_PORT=587

# SMTP login username (usually your email address)
MAIL_USER="no-reply@example.com"

# SMTP password or app-specific password
MAIL_PASS="your-smtp-password"
